# Where the agent FastAPI service is reachable.
# Local dev: leave default. ECS: set to the internal ALB DNS for the agent service.
AGENT_BASE_URL="http://127.0.0.1:8080"

# Shared secret for service-to-service auth, sent as the X-Service-Auth header.
# Must match the value the agent service was started with. Leave blank for
# unauthenticated local dev (the agent will warn at boot).
AGENT_SERVICE_AUTH_SECRET=""

# How long to wait for an agent turn to complete (seconds). Long-running
# Glue job turns can exceed the default httpx timeout.
AGENT_REQUEST_TIMEOUT_SECONDS="600"

# Chainlit's own auth token for its dashboard / data layer. Required by
# Chainlit at boot — generate one with `chainlit create-secret`.
CHAINLIT_AUTH_SECRET=""

# Chainlit Data Layer connection string. Leave blank to run without
# persistence (threads vanish on refresh). The local-stack script sets
# this automatically; for deployed environments, point at RDS Postgres.
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=""
